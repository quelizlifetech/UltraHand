generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum Role {
  doctor
  patient
}

enum HandSide {
  Left
  Right
  Both
}

enum PatientStatus {
  Active
  Recovering
  Completed
}

enum TherapyMode {
  Mechanical_Stimulation @map("Mechanical Stimulation")
  Passive
  Assistive
  Active
}

enum SessionStatus {
  Scheduled
  Completed
  Skipped
  InProgress
}

// ============================================================
// USER
// ============================================================

model User {
  id   String @id @default(cuid())
  name String

  email String? @unique
  phone String? @unique

  password String
  role     Role

  mustChangePassword Boolean @default(false)
  mustSetupProfile   Boolean @default(false)

  firstName    String?
  lastName     String?
  profilePhoto String? @db.Text

  // 🆕 EMAIL CHANGE TRACKING
  // First time setting email = 1, each subsequent edit increments.
  // After reaching 5, emailLocked becomes true. Doctor can unlock.
  emailChangeCount Int     @default(0)
  emailLocked      Boolean @default(false)

  createdAt DateTime @default(now())

  patients       Patient[] @relation("DoctorPatients")
  patientProfile Patient?  @relation("PatientUser")
  doctorProfile  DoctorProfile?

  sentMessages     Message[] @relation("Sender")
  receivedMessages Message[] @relation("Receiver")
}

// ============================================================
// DOCTOR PROFILE
// ============================================================

model DoctorProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  username  String  @unique
  firstName String
  lastName  String

  occupation String?

  profilePhoto String? @db.Text

  clinicName     String?
  clinicLocation String?
  clinicTimings  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================
// PATIENT
// ============================================================

model Patient {
  id        String @id @default(cuid())
  patientId String @unique

  name      String
  age       Int
  diagnosis String
  category  String
  handSide  HandSide

  status PatientStatus @default(Active)

  doctorId String
  doctor   User   @relation("DoctorPatients", fields: [doctorId], references: [id])

  userId String? @unique
  user   User?   @relation("PatientUser", fields: [userId], references: [id])

  createdAt DateTime @default(now())

  therapyConfig TherapyConfig?
  baselineROM   BaselineROM?

  plans    TherapyPlan[]
  sessions Session[]
}

// ============================================================
// THERAPY CONFIG
// ============================================================

model TherapyConfig {
  id        String  @id @default(cuid())
  patientId String  @unique
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  sessionsPerDay  Int
  therapyMode     TherapyMode
  durationMinutes Int

  affectedJoints String[]

  severityLevel String
}

// ============================================================
// BASELINE ROM
// ============================================================

model BaselineROM {
  id        String  @id @default(cuid())
  patientId String  @unique
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  index_mcp Float
  index_pip Float
  index_dip Float

  middle_mcp Float
  middle_pip Float
  middle_dip Float

  ring_mcp Float
  ring_pip Float
  ring_dip Float

  little_mcp Float
  little_pip Float
  little_dip Float

  thumb_mcp Float
  thumb_ip  Float

  wrist_flexion          Float
  wrist_extension        Float
  wrist_radial_deviation Float
  wrist_ulnar_deviation  Float
}

// ============================================================
// THERAPY PLAN
// ============================================================

model TherapyPlan {
  id String @id @default(cuid())

  patientId String
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  intensity   String
  repetitions Int
  targetROM   Float

  aiReport Json?

  isApproved  Boolean @default(false)
  isFinalized Boolean @default(false)

  totalDays Int @default(0)

  startedAt   DateTime?
  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions Session[]

  @@index([patientId])
}

// ============================================================
// SESSION
// ============================================================

model Session {
  id String @id @default(cuid())

  planId String
  plan   TherapyPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  patientId String
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  dayInPlan Int

  status SessionStatus @default(Completed)

  date DateTime @default(now())

  therapyMode TherapyMode?

  avgROM          Float?
  recoveryPercent Float?

  painLevel Int     @default(0)
  fatigue   Boolean @default(false)

  notes String?

  metrics SessionMetric[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([planId, dayInPlan])
  @@index([patientId])
  @@index([planId])
}

// ============================================================
// SESSION METRIC
// ============================================================

model SessionMetric {
  id String @id @default(cuid())

  sessionId String
  session   Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  jointName String

  angle Float
  speed Float

  targetAngle Float?

  withinTarget Boolean?

  @@index([sessionId])
}

// ============================================================
// MESSAGE
// ============================================================

model Message {
  id String @id @default(cuid())

  senderId String
  sender   User   @relation("Sender", fields: [senderId], references: [id])

  receiverId String
  receiver   User   @relation("Receiver", fields: [receiverId], references: [id])

  message String

  isRead Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([senderId])
  @@index([receiverId])
}
